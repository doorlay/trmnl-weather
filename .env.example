# Plugin UUID from TRMNL dashboard (required)
TRMNL_PLUGIN_UUID=your-plugin-uuid-here

# AccuWeather hourly forecast URL (optional, defaults to Capitol Hill, Seattle)
ACCUWEATHER_URL=https://www.accuweather.com/en/us/capitol-hill/98102/hourly-weather-forecast/2254014

# Override location name displayed on the device (optional, scraped from page if unset)
LOCATION_NAME="Capitol Hill, Seattle, WA"
