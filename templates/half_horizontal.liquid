      </div>
      <div class="stat-row">
        <svg class="stat-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512"><path d="M169.4 470.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 370.8 224 64c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 306.7L54.6 265.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160z"/></svg>
        <span class="stat-value">{{ lowTemp }}</span>
      </div>
      <div class="stat-row">
        <svg class="stat-drop" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512"><path d="M192 512C86 512 0 426 0 320C0 228.8 130.2 57.7 166.6 11.7C172.6 4.2 181.5 0 191.1 0L192 0L192.9 0C202.5 0 211.4 4.2 217.4 11.7C253.8 57.7 384 228.8 384 320C384 426 298 512 192 512z"/></svg>
        <span class="stat-value">{{ rainPercent }}</span>
      </div>
    </div>
  </div>
</div>

<div class="title_bar">
  <img class="image" src="https://usetrmnl.com/images/plugins/trmnl--render.svg">
  <span class="title">{{ trmnl.plugin_settings.instance_name }}</span>
</div>

<style>
  .weather-wrapper {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    box-sizing: border-box;
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
  }

  .weather-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 8px 16px 0;
  }

  .weather-location {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.3px;
  }

  .weather-date {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.2px;
    opacity: 0.7;
  }

  .weather-main {
    display: flex;
    align-items: center;
    justify-content: space-around;
    flex: 1;
    padding: 0 20px;
    box-sizing: border-box;
    gap: 24px;
  }

  .weather-current {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .weather-icon {
    width: 96px;
    height: 96px;
    flex-shrink: 0;
  }

  .weather-icon svg {
    width: 100%;
    height: 100%;
  }

  .weather-temp-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .weather-temp-big {
    font-size: 64px;
    font-weight: 700;
    letter-spacing: -2px;
    line-height: 1;
  }

  .weather-feels-label {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.2px;
    margin-top: 4px;
    opacity: 0.7;
  }

  .weather-stats {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .stat-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.5px;
    white-space: nowrap;
  }

  .stat-arrow {
    width: 14px;
    height: 18px;
  }

  .stat-drop {
    width: 14px;
    height: 18px;
  }

  .stat-value {
    line-height: 1;
  }
</style>
