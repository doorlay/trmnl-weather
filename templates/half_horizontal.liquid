      <div class="weather-temp-block">
        <span class="weather-temp-big">{{ currentRealFeel }}</span>
        <span class="weather-feels-label">Feels like</span>
      </div>
    </div>
    <div class="weather-stats">
      <div class="stat-row">
        <svg class="stat-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512"><path d="M214.6 41.4c-12.5-12.5-32.8-12.5-45.3 0l-160 160c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L160 141.2 160 448c0 17.7 14.3 32 32 32s32-14.3 32-32l0-306.7L329.4 246.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3l-160-160z"/></svg>
