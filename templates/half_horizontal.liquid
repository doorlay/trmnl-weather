<div class="weather-container">
  {% for hour in hours limit: 8 %}
  <div class="weather-col">
    <span class="weather-time">{{ hour.time }}</span>
    <div class="weather-icon">
      {% if hour.icon == "sunny" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="32" cy="32" r="12" fill="black"/>
        <line x1="32" y1="4" x2="32" y2="14" stroke="black" stroke-width="3" stroke-linecap="round"/>
        <line x1="32" y1="50" x2="32" y2="60" stroke="black" stroke-width="3" stroke-linecap="round"/>
        <line x1="4" y1="32" x2="14" y2="32" stroke="black" stroke-width="3" stroke-linecap="round"/>
        <line x1="50" y1="32" x2="60" y2="32" stroke="black" stroke-width="3" stroke-linecap="round"/>
        <line x1="12.2" y1="12.2" x2="19.1" y2="19.1" stroke="black" stroke-width="3" stroke-linecap="round"/>
        <line x1="44.9" y1="44.9" x2="51.8" y2="51.8" stroke="black" stroke-width="3" stroke-linecap="round"/>
        <line x1="12.2" y1="51.8" x2="19.1" y2="44.9" stroke="black" stroke-width="3" stroke-linecap="round"/>
        <line x1="44.9" y1="19.1" x2="51.8" y2="12.2" stroke="black" stroke-width="3" stroke-linecap="round"/>
      </svg>

      {% elsif hour.icon == "clear" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M40 10 C34 12 28 18 28 28 C28 38 36 46 46 46 C48 46 50 45.5 52 45 C48 52 41 57 32 57 C20 57 10 47 10 34 C10 21 20 11 32 11 C35 11 37.5 10.5 40 10Z" fill="black"/>
      </svg>

      {% elsif hour.icon == "partly_cloudy" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="24" cy="20" r="9" fill="black"/>
        <line x1="24" y1="4" x2="24" y2="9" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="4" y1="20" x2="9" y2="20" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="12" y1="8" x2="15.5" y2="11.5" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="36" y1="8" x2="32.5" y2="11.5" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="12" y1="32" x2="15.5" y2="28.5" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M18 40 C16 40 12 40 10 40 C5 40 2 44 2 48 C2 52 5 56 10 56 L50 56 C55 56 58 52 58 48 C58 44 55 40 50 40 C48 37 44 34 39 34 C34 34 30 37 28 40 C26 39 22 40 18 40Z" fill="black"/>
      </svg>

      {% elsif hour.icon == "mostly_clear" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M34 6 C30 8 26 13 26 20 C26 28 32 34 40 34 C41 34 42 33.8 43 33.5 C40 38 35 41 29 41 C20 41 13 34 13 25 C13 16 20 9 29 9 C31 9 32.5 8.5 34 6Z" fill="black"/>
        <path d="M18 44 C16 44 12 44 10 44 C5 44 2 47.5 2 51 C2 54.5 5 58 10 58 L50 58 C55 58 58 54.5 58 51 C58 47.5 55 44 50 44 C48 41.5 44 39 39 39 C34 39 30 41.5 28 44 C26 43 22 44 18 44Z" fill="black"/>
      </svg>

      {% elsif hour.icon == "mostly_cloudy" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="22" cy="16" r="7" fill="black"/>
        <line x1="22" y1="3" x2="22" y2="7" stroke="black" stroke-width="2" stroke-linecap="round"/>
        <line x1="9" y1="16" x2="13" y2="16" stroke="black" stroke-width="2" stroke-linecap="round"/>
        <line x1="12.6" y1="6.6" x2="15.5" y2="9.5" stroke="black" stroke-width="2" stroke-linecap="round"/>
        <path d="M22 30 C20 30 17 30 15 30 C10 30 6 33 6 37 C6 41 10 44 15 44 L34 44 C39 44 42 41 42 37" stroke="black" stroke-width="2.5" fill="none"/>
        <path d="M18 44 C16 44 12 44 10 44 C5 44 2 47.5 2 51 C2 54.5 5 58 10 58 L50 58 C55 58 58 54.5 58 51 C58 47.5 55 44 50 44 C48 41.5 44 39 39 39 C34 39 30 41.5 28 44 C26 43 22 44 18 44Z" fill="black"/>
      </svg>

      {% elsif hour.icon == "cloudy" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M22 28 C20 28 17 28 15 28 C10 28 6 31 6 35 C6 39 10 42 15 42 L44 42 C49 42 52 39 52 35 C52 31 49 28 44 28 C42 25 39 22 34 22 C29 22 26 25 24 28 C23 27.5 22 28 22 28Z" fill="black"/>
        <path d="M18 44 C16 44 12 44 10 44 C5 44 2 47.5 2 51 C2 54.5 5 58 10 58 L50 58 C55 58 58 54.5 58 51 C58 47.5 55 44 50 44 C48 41.5 44 39 39 39 C34 39 30 41.5 28 44 C26 43 22 44 18 44Z" fill="black"/>
      </svg>

      {% elsif hour.icon == "rain" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M16 26 C14 26 10 26 8 26 C3 26 0 29.5 0 33 C0 36.5 3 40 8 40 L52 40 C57 40 60 36.5 60 33 C60 29.5 57 26 52 26 C50 23.5 46 21 41 21 C36 21 32 23.5 30 26 C28 25 24 26 16 26Z" fill="black"/>
        <line x1="16" y1="44" x2="12" y2="56" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="30" y1="44" x2="26" y2="56" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="44" y1="44" x2="40" y2="56" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
      </svg>

      {% elsif hour.icon == "thunderstorm" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M16 22 C14 22 10 22 8 22 C3 22 0 25.5 0 29 C0 32.5 3 36 8 36 L52 36 C57 36 60 32.5 60 29 C60 25.5 57 22 52 22 C50 19.5 46 17 41 17 C36 17 32 19.5 30 22 C28 21 24 22 16 22Z" fill="black"/>
        <polygon points="35,38 26,50 32,50 23,62 38,48 32,48 38,38" fill="black"/>
        <line x1="14" y1="40" x2="11" y2="49" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="50" y1="40" x2="47" y2="49" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
      </svg>

      {% elsif hour.icon == "snow" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M16 26 C14 26 10 26 8 26 C3 26 0 29.5 0 33 C0 36.5 3 40 8 40 L52 40 C57 40 60 36.5 60 33 C60 29.5 57 26 52 26 C50 23.5 46 21 41 21 C36 21 32 23.5 30 26 C28 25 24 26 16 26Z" fill="black"/>
        <circle cx="15" cy="47" r="2.5" fill="black"/>
        <circle cx="30" cy="47" r="2.5" fill="black"/>
        <circle cx="45" cy="47" r="2.5" fill="black"/>
        <circle cx="22" cy="55" r="2.5" fill="black"/>
        <circle cx="37" cy="55" r="2.5" fill="black"/>
      </svg>

      {% elsif hour.icon == "sleet" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M16 26 C14 26 10 26 8 26 C3 26 0 29.5 0 33 C0 36.5 3 40 8 40 L52 40 C57 40 60 36.5 60 33 C60 29.5 57 26 52 26 C50 23.5 46 21 41 21 C36 21 32 23.5 30 26 C28 25 24 26 16 26Z" fill="black"/>
        <line x1="16" y1="44" x2="13" y2="53" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
        <circle cx="30" cy="49" r="2.5" fill="black"/>
        <line x1="44" y1="44" x2="41" y2="53" stroke="black" stroke-width="2.5" stroke-linecap="round"/>
        <circle cx="23" cy="57" r="2.5" fill="black"/>
      </svg>

      {% elsif hour.icon == "fog" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="6" y1="16" x2="58" y2="16" stroke="black" stroke-width="4" stroke-linecap="round"/>
        <line x1="10" y1="28" x2="54" y2="28" stroke="black" stroke-width="4" stroke-linecap="round"/>
        <line x1="6" y1="40" x2="58" y2="40" stroke="black" stroke-width="4" stroke-linecap="round"/>
        <line x1="14" y1="52" x2="50" y2="52" stroke="black" stroke-width="4" stroke-linecap="round"/>
      </svg>

      {% elsif hour.icon == "wind" %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M6 20 Q22 12 42 20 Q50 24 54 16" stroke="black" stroke-width="3" fill="none" stroke-linecap="round"/>
        <path d="M6 34 Q18 26 34 34 Q46 40 58 30" stroke="black" stroke-width="3" fill="none" stroke-linecap="round"/>
        <path d="M6 48 Q16 40 30 48 Q42 54 50 44" stroke="black" stroke-width="3" fill="none" stroke-linecap="round"/>
      </svg>

      {% else %}
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M16 26 C14 26 10 26 8 26 C3 26 0 29.5 0 33 C0 36.5 3 40 8 40 L52 40 C57 40 60 36.5 60 33 C60 29.5 57 26 52 26 C50 23.5 46 21 41 21 C36 21 32 23.5 30 26 C28 25 24 26 16 26Z" fill="black"/>
      </svg>
      {% endif %}
    </div>
    <span class="weather-temp">{{ hour.temperature }}</span>
    <span class="weather-precip">{{ hour.precip }}</span>
  </div>
  {% endfor %}
</div>

<div class="title_bar">
  <img class="image" src="https://usetrmnl.com/images/plugins/trmnl--render.svg">
  <span class="title">{{ trmnl.plugin_settings.instance_name }}</span>
</div>

<style>
  .weather-container {
    display: flex;
    justify-content: space-around;
    align-items: flex-start;
    width: 100%;
    height: 100%;
    padding: 12px 8px 0;
    box-sizing: border-box;
  }

  .weather-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    min-width: 0;
    gap: 2px;
  }

  .weather-time {
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.5px;
    white-space: nowrap;
  }

  .weather-icon {
    width: 56px;
    height: 56px;
    padding: 4px 0;
  }

  .weather-icon svg {
    width: 100%;
    height: 100%;
  }

  .weather-temp {
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -1px;
  }

  .weather-precip {
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 14px;
    color: #666;
    white-space: nowrap;
  }
</style>
